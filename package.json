{
	"name": "@steve02081504/virtual-console",
	"version": "0.2.0",
	"description": "A virtual console for capturing and manipulating terminal output.",
	"main": "main.mjs",
	"type": "module",
	"exports": {
		".": {
			"browser": {
				"types": "./browser.d.mts",
				"default": "./browser.mjs"
			},
			"node": {
				"types": "./node.d.mts",
				"default": "./node.mjs"
			},
			"types": "./main.d.mts",
			"default": "./main.mjs"
		},
		"./node": {
			"types": "./node.d.mts",
			"default": "./node.mjs"
		},
		"./browser": {
			"types": "./browser.d.mts",
			"default": "./browser.mjs"
		},
		"./wire/protocol": {
			"types": "./src/wire/protocol.d.mts",
			"default": "./src/wire/protocol.mjs"
		},
		"./wire/server": {
			"types": "./src/wire/server.d.mts",
			"default": "./src/wire/server.mjs"
		},
		"./wire/client": {
			"types": "./src/wire/client.d.mts",
			"default": "./src/wire/client.mjs"
		}
	},
	"types": "./main.d.mts",
	"scripts": {
		"test": "node test.mjs"
	},
	"keywords": [
		"console",
		"virtual",
		"capture",
		"terminal",
		"output"
	],
	"author": "steve02081504",
	"bugs": {
		"url": "https://github.com/steve02081504/virtual-console/issues"
	},
	"homepage": "https://github.com/steve02081504/virtual-console#readme",
	"dependencies": {
		"ansi_up": "latest",
		"ansi-escapes": "latest",
		"full-proxy": "latest",
		"supports-ansi": "latest"
	}
}
